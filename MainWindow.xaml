<Window x:Class="CyberSecurityBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Your Cyber Friend - Cybersecurity Awareness Bot" 
        Height="760" Width="960"
        Background="#0F172A" Foreground="White" FontFamily="Consolas">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Chat Area -->
            <RowDefinition Height="Auto"/>
            <!-- Input -->
        </Grid.RowDefinitions>

        <!-- Header with Compact ASCII Art -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20" HorizontalAlignment="Center">
            <TextBlock Text="🤖 Your Cyber Friend" 
                       FontSize="34" FontWeight="Bold" 
                       Foreground="#22D3EE" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <!-- Compact ASCII Art -->
            <TextBlock Text="   _____ ___ _ _ ____ ____ _ _ _____ 
  / ___/ / _ \| | | | / __ \| | | |  _  \ 
 / /    | | | | | | | | |  | | | | | | | | 
 | |___ | |_| | |_| | | |__| | |_| | |_| | 
  \____/ \___/ \___/  \____/ \___/ |_____/ 

        Y O U R   C Y B E R   F R I E N D" 
                       FontSize="8.8" Foreground="#67E8F9" 
                       HorizontalAlignment="Center" TextAlignment="Center"
                       Margin="0,5,0,15"/>

            <TextBlock Text="Cybersecurity Awareness Bot" 
                       FontSize="16" Foreground="#94A3B8" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Chat Area -->
        <ScrollViewer x:Name="chatScroll" Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
            <TextBlock x:Name="tbChat" TextWrapping="Wrap" FontSize="15.5" 
                       Background="#1E2937" Padding="20"/>
        </ScrollViewer>

        <!-- Input Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="txtInput" Height="58" FontSize="16" 
                     Background="#334155" Foreground="White" 
                     VerticalContentAlignment="Center" Padding="15"
                     KeyDown="txtInput_KeyDown"/>

            <Button Grid.Column="1" Content="Send" Width="130" Height="58" 
                    Margin="12,0,0,0" Background="#22D3EE" Foreground="#0F172A" 
                    FontSize="16" FontWeight="Bold" Click="btnSend_Click"/>

            <Button Grid.Column="2" Content="Exit" Width="110" Height="58" 
                    Margin="12,0,0,0" Background="#EF4444" Foreground="White" 
                    FontSize="16" FontWeight="Bold" Click="btnExit_Click"/>
        </Grid>
    </Grid>
</Window>